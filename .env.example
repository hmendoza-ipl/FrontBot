# Frontbot Demo - Variables de Entorno
# Copia este archivo como .env.local y configura tus valores

# n8n webhook para IA (opcional - si no se configura usa respuestas de demo)
N8N_AI_WEBHOOK_URL=https://tu-n8n.tudominio.com/webhook/frontbot-ai

# Email con Resend (opcional - para notificaciones)
MAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Frontbot <no-reply@tudominio.com>

# Puerto (opcional, default 3000)
PORT=3000
