# ─── Frontbot Hotel — Variables de entorno ───────────────────────────────────
# Copia como .env para desarrollo, o configura en Coolify UI.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Coolify: HOST = nombre del servicio interno de Postgres
#DATABASE_URL="postgresql://frontbot_user:PASSWORD@localhost:5432/frontbot?schema=public"
DATABASE_URL="postgresql://postgres:1NRbfCVMsSyiMqtiXgNytOLGNiT5nzN6CYAKnbVjV3aiuVXqMhEIYRkKrKVQPH4a@217.77.7.92:3000/postgres?schema=public"
# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV="production"
# PORT lo inyecta Coolify automáticamente (next start -p ${PORT:-3000})

# ─── Seed al boot ─────────────────────────────────────────────────────────────
SEED_ON_BOOT="false"   # "true" para cargar datos demo la primera vez

# ─── Mail (Resend) — opcional ─────────────────────────────────────────────────
MAIL_PROVIDER="resend"
RESEND_API_KEY=""
MAIL_FROM="Frontbot Hotel <noreply@tudominio.com>"

# ─── n8n AI Webhook — opcional ───────────────────────────────────────────────
N8N_AI_WEBHOOK_URL=""
